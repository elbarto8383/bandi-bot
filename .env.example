# ── KIRANET Bandi Bot – configurazione ─────────────────────────────────────
# Copia questo file in .env e compila i valori reali

# Token del Bot Telegram (da @BotFather)
TELEGRAM_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff1234567890

# Chat ID destinatario (ID utente, gruppo o canale)
# Per un gruppo: -100xxxxxxxxxx
# Per un utente singolo: il tuo chat_id (es. 44413116)
# Per un canale: @nome_canale oppure l'ID numerico
TELEGRAM_CHAT_IDS=44413116,
